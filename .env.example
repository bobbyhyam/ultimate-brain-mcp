# Required — Notion integration secret
NOTION_INTEGRATION_SECRET=secret_xxx

# Required — Primary database data source IDs (run setup_dev.py to auto-discover)
UB_TASKS_DS_ID=
UB_PROJECTS_DS_ID=
UB_NOTES_DS_ID=
UB_TAGS_DS_ID=
UB_GOALS_DS_ID=

# Optional — Secondary database data source IDs
UB_WORK_SESSIONS_DS_ID=
UB_MILESTONES_DS_ID=
UB_PEOPLE_DS_ID=
UB_BOOKS_DS_ID=
UB_READING_LOG_DS_ID=
UB_GENRES_DS_ID=
UB_RECIPES_DS_ID=
UB_MEAL_PLANNER_DS_ID=

# Remote MCP server (optional — omit for default stdio transport)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# SSO authentication (optional — only used when MCP_TRANSPORT is not stdio)
# Users connecting to the MCP server URL will be redirected to this provider's login page.
OAUTH_ISSUER_URL=https://your-provider.example.com
OAUTH_CLIENT_ID=Client ID from your provider
